[{"id": 1, "texto": "ACID significa:", "opciones": ["Acidity Chemical", "Atomicity Consistency Isolation Durability", "Advanced Coding", "Algo complejo"], "dificultad": 1, "respuestaCorrecta": "s"}, {"id": 2, "texto": "Atomicity en transacciones:", "opciones": ["Datos grandes", "TODO o NADA (todo-o-nada)", "Velocidad", "Seguridad"], "dificultad": 1, "respuestaCorrecta": "s"}, {"id": 3, "texto": "Consistency significa:", "opciones": ["Datos comprimidos", "BD pasa de estado válido a válido", "Copia de datos", "Frecuencia"], "dificultad": 1, "respuestaCorrecta": "s"}, {"id": 4, "texto": "Isolation en transacciones es:", "opciones": ["Datos aislados", "Transacciones concurrentes no interfieren", "Encriptación", "Backup"], "dificultad": 1, "respuestaCorrecta": "s"}, {"id": 5, "texto": "Durability asegura:", "opciones": ["Datos únicos", "Datos guardados permanentemente tras commit", "Sin errores", "Sin pérdidas"], "dificultad": 1, "respuestaCorrecta": "s"}, {"id": 6, "texto": "BEGIN; inicia:", "opciones": ["Consulta", "Transacción", "Tabla", "Usuario"], "dificultad": 1, "respuestaCorrecta": "s"}, {"id": 7, "texto": "COMMIT en transacción:", "opciones": ["Revierte cambios", "Confirma cambios (permanente)", "Pausa", "Error"], "dificultad": 1, "respuestaCorrecta": "s"}, {"id": 8, "texto": "ROLLBACK en transacción:", "opciones": ["Confirma", "Revierte cambios (abandona)", "Pausa", "Continúa"], "dificultad": 1, "respuestaCorrecta": "s"}, {"id": 9, "texto": "Dirty Read es cuando:", "opciones": ["Lee datos no confirmados de otra transacción", "Lee todos datos", "Lee datos viejos", "Error"], "dificultad": 1, "respuestaCorrecta": "a"}, {"id": 10, "texto": "Deadlock ocurre cuando:", "opciones": ["Dos transacciones se bloquean mutuamente", "Hay un error", "Base de datos falla", "Puerto ocupado"], "dificultad": 1, "respuestaCorrecta": "a"}, {"id": 11, "texto": "READ UNCOMMITTED aísla:", "opciones": ["Mucho", "Poco (permite dirty reads)", "Nada", "Todo"], "dificultad": 2, "respuestaCorrecta": "s"}, {"id": 12, "texto": "READ COMMITTED previene:", "opciones": ["Dirty reads", "Dirty reads + non-repeatable reads", "Todo", "Nada"], "dificultad": 2, "respuestaCorrecta": "a"}, {"id": 13, "texto": "REPEATABLE READ garantiza:", "opciones": ["Lectura consistente en transacción", "Sin phantom reads", "Sin cambios", "Sin errores"], "dificultad": 2, "respuestaCorrecta": "a"}, {"id": 14, "texto": "SERIALIZABLE es:", "opciones": ["Rápido", "Nivel máximo aislamiento (transacciones secuenciales)", "Peligroso", "Sin usar"], "dificultad": 2, "respuestaCorrecta": "s"}, {"id": 15, "texto": "Non-repeatable read es:", "opciones": ["Leer no confirmado", "Fila cambia entre lecturas en transacción", "Lectura lenta", "Error"], "dificultad": 2, "respuestaCorrecta": "s"}, {"id": 16, "texto": "Phantom read ocurre cuando:", "opciones": ["Fila cambia", "Aparecen/desaparecen filas entre transacciones", "Tabla falla", "Error"], "dificultad": 2, "respuestaCorrecta": "s"}, {"id": 17, "texto": "Timeout de transacción es:", "opciones": ["Nunca expira", "Máximo tiempo antes de rollback automático", "Duración query", "Error"], "dificultad": 2, "respuestaCorrecta": "s"}, {"id": 18, "texto": "Lock en transacción previene:", "opciones": ["Acceso", "Modificaciones conflictivas de otra tx", "Todo", "Nada"], "dificultad": 2, "respuestaCorrecta": "s"}, {"id": 19, "texto": "Shared lock permite:", "opciones": ["Lectura múltiple (no escritura)", "Escribir", "Borrar", "Nada"], "dificultad": 2, "respuestaCorrecta": "a"}, {"id": 20, "texto": "Exclusive lock permite:", "opciones": ["Solo una transacción (lectura y escritura)", "Cualquiera leer", "Múltiples", "Nada"], "dificultad": 2, "respuestaCorrecta": "a"}, {"id": 21, "texto": "MVCC (Multi-Version Concurrency Control):", "opciones": ["Varias copias datos para aislamiento", "Versión única", "Control lento", "Error"], "dificultad": 3, "respuestaCorrecta": "a"}, {"id": 22, "texto": "Two-Phase Locking (2PL):", "opciones": ["2 bases de datos", "Bloquear luego liberar ordenado", "2 transacciones", "Nada"], "dificultad": 3, "respuestaCorrecta": "s"}, {"id": 23, "texto": "Optimistic locking confía en:", "opciones": ["Locks", "Pocas colisiones, detecta al commit", "Usuarios", "Nada"], "dificultad": 3, "respuestaCorrecta": "s"}, {"id": 24, "texto": "Pessimistic locking:", "opciones": ["Bloquea desde inicio (previene conflicto)", "Confianza", "Rápido", "Sin usar"], "dificultad": 3, "respuestaCorrecta": "a"}, {"id": 25, "texto": "Savepoint WITHIN transacción:", "opciones": ["Nuevo punto rollback parcial", "Commit parcial", "Error", "Transacción nueva"], "dificultad": 3, "respuestaCorrecta": "a"}, {"id": 26, "texto": "WAL (Write-Ahead Logging):", "opciones": ["Escribe disco ANTES cambios memoria", "Escribe después", "Sin usar", "Error"], "dificultad": 3, "respuestaCorrecta": "a"}, {"id": 27, "texto": "Cascading Rollback ocurre cuando:", "opciones": ["Una tx falla, revierte dependientes", "Una falla", "Muchas fallan", "Error"], "dificultad": 3, "respuestaCorrecta": "a"}, {"id": 28, "texto": "Abort rate en transacciones es:", "opciones": ["Porcentaje fallidas/total", "Velocidad", "Número queries", "Tiempo"], "dificultad": 3, "respuestaCorrecta": "a"}, {"id": 29, "texto": "Checkpoint en BD es:", "opciones": ["Punto sincronización disco de cambios", "Revisión datos", "Copia", "Error"], "dificultad": 3, "respuestaCorrecta": "a"}, {"id": 30, "texto": "Recovery from crash usa:", "opciones": ["Memoria", "WAL para rehacer transacciones", "Backup", "Nothing"], "dificultad": 3, "respuestaCorrecta": "s"}]
